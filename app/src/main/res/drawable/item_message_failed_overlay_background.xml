<?xml version="1.0" encoding="utf-8"?>
<!-- Mirrors item_sent_background's corners exactly (square on the tail corner) so the overlay
     never reads as a square patch sitting on top of the rounded bubble. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <corners
        android:bottomLeftRadius="@dimen/normal_margin"
        android:bottomRightRadius="0dp"
        android:topLeftRadius="@dimen/normal_margin"
        android:topRightRadius="@dimen/normal_margin" />

    <solid android:color="#40000000" />

</shape>
