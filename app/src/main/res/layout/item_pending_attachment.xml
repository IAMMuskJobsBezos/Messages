<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="64dp"
    android:layout_height="64dp"
    android:layout_marginEnd="@dimen/medium_margin">

    <ImageView
        android:id="@+id/pending_attachment_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/chip_rectangle_background"
        android:scaleType="centerCrop"
        tools:ignore="ContentDescription" />

    <ImageView
        android:id="@+id/pending_attachment_play_badge"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_vector_play_circle_outline"
        android:visibility="gone"
        tools:ignore="ContentDescription"
        tools:visibility="visible" />

    <ImageView
        android:id="@+id/pending_attachment_remove"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_gravity="top|end"
        android:layout_margin="2dp"
        android:background="@drawable/circle_background"
        android:padding="3dp"
        android:src="@drawable/ic_cross_vector"
        tools:ignore="ContentDescription" />

</FrameLayout>
