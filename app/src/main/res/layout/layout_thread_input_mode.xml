<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/thread_input_mode_holder"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="@dimen/activity_margin"
    android:paddingTop="@dimen/medium_margin"
    android:paddingBottom="@dimen/medium_margin">

    <!-- Idle state: two large side-by-side buttons -->
    <LinearLayout
        android:id="@+id/input_mode_idle_holder"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/input_mode_voice_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/normal_margin"
            android:layout_weight="1"
            android:background="@drawable/button_rounded_rect_background"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingVertical="20dp">

            <ImageView
                android:id="@+id/input_mode_voice_icon"
                android:layout_width="@dimen/list_icon_size_large"
                android:layout_height="@dimen/list_icon_size_large"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_microphone_vector" />

            <org.fossify.commons.views.MyTextView
                android:id="@+id/input_mode_voice_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/normal_margin"
                android:gravity="center"
                android:text="@string/voice_to_text_button"
                android:textSize="@dimen/extra_big_text_size" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/input_mode_keyboard_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/normal_margin"
            android:layout_weight="1"
            android:background="@drawable/button_rounded_rect_background"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingVertical="20dp">

            <ImageView
                android:id="@+id/input_mode_keyboard_icon"
                android:layout_width="@dimen/list_icon_size_large"
                android:layout_height="@dimen/list_icon_size_large"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_keyboard_vector" />

            <org.fossify.commons.views.MyTextView
                android:id="@+id/input_mode_keyboard_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/normal_margin"
                android:gravity="center"
                android:text="@string/keyboard_button"
                android:textSize="@dimen/extra_big_text_size" />
        </LinearLayout>
    </LinearLayout>

    <!-- Keyboard state: slim Voice pill pinned above the system keyboard -->
    <LinearLayout
        android:id="@+id/input_mode_voice_pill"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/button_rounded_background_outline"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="22dp"
        android:paddingVertical="@dimen/normal_margin"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="gone">

        <ImageView
            android:id="@+id/input_mode_voice_pill_icon"
            android:layout_width="@dimen/new_conversation_icon_size"
            android:layout_height="@dimen/new_conversation_icon_size"
            android:importantForAccessibility="no"
            android:src="@drawable/ic_microphone_vector" />

        <org.fossify.commons.views.MyTextView
            android:id="@+id/input_mode_voice_pill_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/activity_margin"
            android:text="@string/voice_button"
            android:textSize="@dimen/big_text_size" />
    </LinearLayout>

    <!-- Listening state: Keyboard pill (exit) + "Listening..." label + Stop button -->
    <LinearLayout
        android:id="@+id/input_mode_listening_holder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="gone">

        <LinearLayout
            android:id="@+id/input_mode_listening_keyboard_pill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/button_rounded_background_outline"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="22dp"
            android:paddingVertical="@dimen/normal_margin">

            <ImageView
                android:id="@+id/input_mode_listening_keyboard_icon"
                android:layout_width="@dimen/new_conversation_icon_size"
                android:layout_height="@dimen/new_conversation_icon_size"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_keyboard_vector" />

            <org.fossify.commons.views.MyTextView
                android:id="@+id/input_mode_listening_keyboard_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/activity_margin"
                android:text="@string/keyboard_button"
                android:textSize="@dimen/big_text_size" />
        </LinearLayout>

        <org.fossify.commons.views.MyTextView
            android:id="@+id/input_mode_listening_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/big_margin"
            android:gravity="center"
            android:text="@string/listening_speak_clearly"
            android:textSize="@dimen/extra_big_text_size" />

        <LinearLayout
            android:id="@+id/input_mode_stop_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/big_margin"
            android:layout_marginHorizontal="54dp"
            android:background="@drawable/button_rounded_rect_background_filled"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="4dp"
            android:paddingVertical="6dp">

            <ImageView
                android:id="@+id/input_mode_stop_icon"
                android:layout_width="@dimen/list_icon_size_large"
                android:layout_height="@dimen/list_icon_size_large"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_stop_vector" />

            <org.fossify.commons.views.MyTextView
                android:id="@+id/input_mode_stop_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/activity_margin"
                android:text="@string/stop_button"
                android:textSize="@dimen/extra_big_text_size" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
